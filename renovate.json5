{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mikutas/my-renovate-config"
  ],
  "customManagers": [
    {
      // rollout-extension
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-.]+?)(?: depName=(?<depName>.+?))(?: packageName=(?<packageName>.+?))?(?: registryUrl=(?<registryUrl>.+?))?\\s.*(?<currentValue>\\d+\\.\\d+\\.\\d+(?:[a-z-]+)?).*"
      ]
    },
    {
      // k3d
      "customType": "regex",
      "managerFilePatterns": [
        "/k3d-default\\.ya?ml/"
      ],
      "matchStrings": [
        "image:\\s*(?<depName>[^:]+):(?<currentValue>v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:-(?<prerelease>[a-z]+\\d+))?(?<compatibility>\\-k3s)(?<build>\\d+))"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "docker.io/rancher/k3s"
    },
    {
      // kind
      "customType": "regex",
      "managerFilePatterns": [
        "/kind.*\\.ya?ml/"
      ],
      "matchStrings": [
        "image:\\s*(?<depName>[^:]+):(?<currentValue>v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+))"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "kindest/node"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["linkerd/linkerd2"],
      // https://docs.renovatebot.com/modules/versioning/
      "versioning": "regex:(?<compatibility>stable|edge)-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)?"
    },
    {
      "matchPackageNames": [
        "/linkerd2/", // CLI
        "/linkerd-crds/",
        "/linkerd-control-plane/",
        "/linkerd-viz/"
      ],
      "groupName": "linkerd",
      "addLabels": [
        "linkerd"
      ]
    },
    {
      "matchPackageNames": [
        "odigos",
        "postgresql"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    }
  ]
}
